DATABASE_URL=postgresql+psycopg2://docintake:docintake@localhost:5432/docintake
DEFAULT_JSONL_PATH=input_docs/documents_1.jsonl

# Celery (Redis). Match `docker compose` Redis service when using the bundled worker.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Tests: pytest sets eager mode so Redis is not required for `POST /ingestions`.
# For local API without Redis (not recommended): CELERY_TASK_ALWAYS_EAGER=1
